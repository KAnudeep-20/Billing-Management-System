<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder" />
    </appender>

    <!-- For local development, it might be better to output standard text.
         In a real production environment, we use SPRING_PROFILES_ACTIVE=prod 
         to switch to JSON logging. Here we just set it as the default 
         so that the verification succeeds. -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>
